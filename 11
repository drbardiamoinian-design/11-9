<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
<title>Air Dodge</title>
<style>
  * { margin:0; padding:0; box-sizing:border-box; }
  body { width:100vw; height:100vh; background:#0b1220; display:flex; flex-direction:column; align-items:center; justify-content:center; overflow:hidden; user-select:none; font-family:monospace; touch-action:none; }
  #hud { display:flex; justify-content:space-between; align-items:center; padding:5px 8px; margin-bottom:4px; }
  #score-display { color:#fff; font-size:14px; letter-spacing:1px; }
  #lives-display { display:flex; gap:6px; }
  .life { width:14px; height:14px; border-radius:50%; background:#ff3333; border:2px solid #ff6666; transition: all 0.3s; }
  .life.lost { border-radius:2px; background:#333; border-color:#555; }
  #canvas-wrap { position:relative; overflow:hidden; border-radius:4px; border:1px solid #223; }
  canvas { display:block; }
</style>
</head>
<body>

<div id="hud">
  <div id="score-display">SCORE: 0</div>
  <div id="lives-display">
    <div class="life" id="life1"></div>
    <div class="life" id="life2"></div>
  </div>
</div>
<div id="canvas-wrap">
  <canvas id="gc"></canvas>
</div>

<script>
const GW = 800, GH = 400;
const PLAYER_X = 80;
const BLUE_W = 50, BLUE_H = 90;
const RED_W  = 22, RED_H  = 90;

// Plane PNG is 512x512 square — render square so proportions are correct
const PLANE_W = 130, PLANE_H = 130;
// Hitbox: the actual aircraft body sits roughly in the middle vertically (35%-65%)
// and nearly full width (6%-94%). At 130px: y+46 to y+84, x+8 to x+122
const PLANE_HIT_LEFT   = 8;
const PLANE_HIT_RIGHT  = 8;   // inset from right
const PLANE_HIT_TOP    = 46;
const PLANE_HIT_BOTTOM = 46;  // inset from bottom

const EXP_DURATION = 700;

// ── SWAP YOUR OWN IMAGES HERE ──────────────────────────────────────────────
// Replace the base64 strings below with your own image data.
// Format: "data:image/png;base64,YOUR_BASE64_HERE"
// or use a URL: "https://example.com/your-image.png"
//
// BLUE_SRC  → shown when player has 2 lives  (wide rectangle)
// RED_SRC   → shown when player has 1 life   (narrow rectangle)
//
// The hitbox does NOT change — it stays BLUE_W×BLUE_H or RED_W×RED_H
// regardless of what image you put here.
// ──────────────────────────────────────────────────────────────────────────
const BLUE_SRC      = 'data:image/png;base64,';
const RED_SRC       = 'data:image/png;base64,';
// ──────────────────────────────────────────────────────────────────────────

const SKYLINE_SRC   = 'data:image/jpeg;base64,';
const PLANE_SRC     = 'data:image/png;base64,';
const EXPLOSION_SRC = 'data:image/png;base64,';

const IMGS = {};
function loadImg(key, src) {
  return new Promise(r => { const i = new Image(); i.onload = () => { IMGS[key] = i; r(); }; i.src = src; });
}

Promise.all([
  loadImg('skyline',   SKYLINE_SRC),
  loadImg('plane',     PLANE_SRC),
  loadImg('red',       RED_SRC),
  loadImg('blue',      BLUE_SRC),
  loadImg('explosion', EXPLOSION_SRC),
]).then(init);

function init() {
  const canvas = document.getElementById('gc');
  const ctx = canvas.getContext('2d');
  const wrap = document.getElementById('canvas-wrap');

  let scale = 1;
  function resize() {
    scale = Math.min((window.innerWidth - 12) / GW, (window.innerHeight - 80) / GH, 1);
    canvas.width  = GW;
    canvas.height = GH;
    canvas.style.width  = (GW * scale) + 'px';
    canvas.style.height = (GH * scale) + 'px';
    wrap.style.width  = (GW * scale) + 'px';
    wrap.style.height = (GH * scale) + 'px';
    document.getElementById('hud').style.width = (GW * scale) + 'px';
  }
  resize();
  window.addEventListener('resize', resize);

  let playerY, planes, lives, score, started, over, invincible, explosion, invTimer;
  let spawnAcc, scoreAcc, lastT, rafId;
  let dragging = false;

  function initState() {
    playerY = GH / 2; planes = []; lives = 2; score = 0;
    started = false; over = false; invincible = false; explosion = null;
    spawnAcc = 0; scoreAcc = 0; lastT = null;
    updateHUD();
  }

  function updateHUD() {
    document.getElementById('score-display').textContent = 'SCORE: ' + score;
    document.getElementById('life1').className = 'life' + (lives >= 1 ? '' : ' lost');
    document.getElementById('life2').className = 'life' + (lives >= 2 ? '' : ' lost');
  }

  function getSpeed(s)   { return 2.2 + s * 0.022; }
  function getSpawnMs(s) { return Math.max(1400, 2800 - s * 10); }
  function randomY()     { return 20 + Math.random() * (GH - 40 - PLANE_H); }

  function startGame() {
    clearTimeout(invTimer);
    initState();
    started = true;
    lastT = null; spawnAcc = 0; scoreAcc = 0;
    cancelAnimationFrame(rafId);
    rafId = requestAnimationFrame(loop);
  }

  function loop(t) {
    if (!lastT) lastT = t;
    const dt = Math.min(t - lastT, 50);
    lastT = t;

    if (started && !over) {
      spawnAcc += dt; scoreAcc += dt;
      const speed = getSpeed(score);

      if (scoreAcc >= 500) { score++; scoreAcc = 0; updateHUD(); }

      planes = planes.map(p => ({ ...p, x: p.x - speed * dt * 0.06 })).filter(p => p.x > -PLANE_W - 10);

      if (spawnAcc >= getSpawnMs(score)) {
        spawnAcc = 0;
        const count = score > 25 && Math.random() < 0.35 ? 2 : 1;
        const used = [];
        for (let i = 0; i < count; i++) {
          let y, tries = 0;
          do { y = randomY(); tries++; } while (used.some(u => Math.abs(u - y) < PLANE_H + 20) && tries < 15);
          used.push(y);
          planes.push({ x: GW + 10, y, id: Math.random() });
        }
      }

      if (!invincible) {
        const pw = lives <= 1 ? RED_W : BLUE_W;
        const ph = lives <= 1 ? RED_H : BLUE_H;
        const pL = PLAYER_X - pw/2, pR = PLAYER_X + pw/2;
        const pT = playerY - ph/2,  pB = playerY + ph/2;
        for (const p of planes) {
          const pl = p.x + PLANE_HIT_LEFT;
          const pr = p.x + PLANE_W - PLANE_HIT_RIGHT;
          const pt = p.y + PLANE_HIT_TOP;
          const pb = p.y + PLANE_H - PLANE_HIT_BOTTOM;
          if (pR > pl && pL < pr && pB > pt && pT < pb) {
            lives = Math.max(0, lives - 1);
            invincible = true;
            explosion = { x: PLAYER_X, y: playerY, t: 0 };
            updateHUD();
            clearTimeout(invTimer);
            invTimer = setTimeout(() => { invincible = false; }, 2000);
            if (lives <= 0) over = true;
            break;
          }
        }
      }

      if (explosion) {
        explosion.t += dt;
        if (explosion.t > EXP_DURATION) explosion = null;
      }
    }

    draw(ctx);
    rafId = requestAnimationFrame(loop);
  }

  function draw(ctx) {
    ctx.clearRect(0, 0, GW, GH);

    ctx.drawImage(IMGS.skyline, 0, 0, GW, GH);
    ctx.fillStyle = 'rgba(8,15,30,0.22)';
    ctx.fillRect(0, 0, GW, GH);

    for (const p of planes) {
      ctx.drawImage(IMGS.plane, p.x, p.y, PLANE_W, PLANE_H);
    }

    const isRed = lives <= 1;
    const pw = isRed ? RED_W : BLUE_W;
    const ph = isRed ? RED_H : BLUE_H;
    ctx.globalAlpha = (invincible && !explosion) ? 0.45 : 1;
    ctx.drawImage(isRed ? IMGS.red : IMGS.blue, PLAYER_X - pw/2, playerY - ph/2, pw, ph);
    ctx.globalAlpha = 1;

    if (explosion) {
      const prog = explosion.t / EXP_DURATION;
      const sz   = 110 * (0.6 + prog * 0.8);
      const op   = prog < 0.3 ? 1 : 1 - (prog - 0.3) / 0.7;
      ctx.globalAlpha = op;
      ctx.drawImage(IMGS.explosion, explosion.x - sz/2, explosion.y - sz/2, sz, sz);
      ctx.globalAlpha = 1;
    }

    if (!started || over) {
      ctx.fillStyle = 'rgba(5,10,20,0.78)';
      ctx.fillRect(0, 0, GW, GH);
      ctx.textAlign = 'center';
      ctx.font = 'bold 38px monospace';
      ctx.fillStyle = over ? '#ff4040' : '#88ccff';
      ctx.fillText(over ? 'GAME OVER' : 'AIR DODGE', GW/2, GH/2 - 55);
      if (over) {
        ctx.font = '16px monospace';
        ctx.fillStyle = '#aaddff';
        ctx.fillText('SCORE: ' + score, GW/2, GH/2 - 15);
      } else {
        ctx.font = '13px monospace';
        ctx.fillStyle = '#7799bb';
        ctx.fillText('DRAG YOUR SHAPE UP & DOWN TO DODGE', GW/2, GH/2 - 10);
      }
      const bx = GW/2 - 60, by = GH/2 + 15;
      ctx.fillStyle = '#1a4080';
      ctx.strokeStyle = '#4488cc';
      ctx.lineWidth = 1.5;
      ctx.beginPath();
      ctx.roundRect(bx, by, 120, 38, 4);
      ctx.fill(); ctx.stroke();
      ctx.fillStyle = '#fff';
      ctx.font = '14px monospace';
      ctx.fillText(over ? 'RETRY' : 'START', GW/2, GH/2 + 39);
    }
  }

  function getGameY(clientY) {
    const rect = canvas.getBoundingClientRect();
    const ph = lives <= 1 ? RED_H : BLUE_H;
    const y = (clientY - rect.top) * (GH / rect.height);
    return Math.max(ph/2, Math.min(GH - ph/2, y));
  }

  canvas.addEventListener('pointerdown', e => {
    if (!started || over) {
      const rect = canvas.getBoundingClientRect();
      const cx = (e.clientX - rect.left) * (GW / rect.width);
      const cy = (e.clientY - rect.top)  * (GH / rect.height);
      if (cx >= GW/2-60 && cx <= GW/2+60 && cy >= GH/2+15 && cy <= GH/2+53) { startGame(); return; }
      if (!started) { startGame(); return; }
      return;
    }
    dragging = true;
    canvas.setPointerCapture(e.pointerId);
    playerY = getGameY(e.clientY);
  });
  canvas.addEventListener('pointermove', e => { if (!dragging || !started || over) return; playerY = getGameY(e.clientY); });
  canvas.addEventListener('pointerup', () => { dragging = false; });

  initState();
  rafId = requestAnimationFrame(loop);
}
</script>
</body>
</html>
